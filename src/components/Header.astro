---
import "../styles/global.css";
---

<header id="site-header">
  <div class="main-nav">
    <nav class="nav-left">
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="#">Productos</a></li>
        <li><a href="#">Información</a></li>
      </ul>
    </nav>

    <div class="logo">
      <img src="/images/aromas-de-roma-logo.webp" alt="Aromas de Roma Logo" id="ar-logo" onclick="window.location.href = '/';"/>
    </div>

    <nav class="nav-right">
      <ul>
        <li><a href="#">Cuenta</a></li>
        <li><a href="#">Contacto</a></li>
        <li><a href="#" class="icon" id="open-search" aria-label="Buscar" title="Buscar"><i class="fa-solid fa-magnifying-glass"></i></a></li>
        <li><a href="#" class="icon" id="open-cart" aria-label="Carrito" title="Carrito"><i class="fa-solid fa-bag-shopping"></i></a></li>
      </ul>
    </nav>
  </div>

  <div class="search-nav">
    <i class="fa-solid fa-magnifying-glass search-icon"></i>
    <input type="text" placeholder="¿Qué te gustaría buscar?" class="search-input" id="search-input" />
    <a href="#" class="icon" id="close-search" aria-label="Cerrar búsqueda" title="Cerrar"><i class="fa-solid fa-xmark"></i></a>
  </div>
</header>

<div class="cart-overlay" id="cart-overlay"></div>
<aside class="cart-sidebar" id="cart-sidebar">
  <div class="cart-header">
    <a href="#" class="icon close-cart" id="close-cart" aria-label="Cerrar carrito" title="Cerrar"><i class="fa-solid fa-xmark"></i></a>
    <h2>Mi carrito</h2>
  </div>
  <hr class="cart-separator" />
  <div class="cart-content">
    <p>El carrito está vacío.</p>
    <a href="#" class="btn-catalog">Explorar catálogo</a>
  </div>
</aside>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Work+Sans:ital,wght@0,100..900;1,100..900&display=swap');
  
  header {
    font-family: 'Montserrat', sans-serif;
    background-color: #f5ede3;
    border-bottom: 1px solid #dbd3ca;
    /* Cambios para hacer el header estático al hacer scroll */
    position: sticky;
    top: 0;
    z-index: 900;
  }
  .main-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1rem 2rem;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .logo {
    width: 95px;
    display: flex;
    justify-content: center;
    cursor: pointer;
  }
  .logo img {
    width: 100%;
    height: auto;
  }
  nav ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .nav-left ul {
    justify-content: flex-start;
  }
  .nav-right ul {
    justify-content: flex-end;
    align-items: center;
  }
  nav a {
    text-decoration: none;
    color: #4a4a4a;
    font-weight: normal;
    transition: color 0.2s ease-in-out;
    text-transform: uppercase;
  }
  nav a:hover {
    color: #d4a373;
  }
  .icon {
    font-size: 1.2rem;
    text-decoration: none;
  }
  header.search-active .main-nav {
    opacity: 0;
    visibility: hidden;
  }
  .search-nav {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 2rem;
    box-sizing: border-box;
    gap: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  header.search-active .search-nav {
    opacity: 1;
    visibility: visible;
  }
  .search-icon {
    font-size: 1.2rem;
    color: #4a4a4a;
  }
  .search-input {
    flex-grow: 1;
    border: none;
    background: transparent;
    font-size: 1.2rem;
    font-family: inherit;
    color: #4a4a4a;
    outline: none;
  }
  .search-input::placeholder {
    color: #a09890;
  }

  /* Estilos del Sidebar del Carrito */
  .cart-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
    font-family: 'Inter', sans-serif;
  }
  .cart-overlay.active {
    opacity: 1;
    visibility: visible;
  }
  .cart-sidebar {
    font-family: 'Inter', sans-serif;
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 400px;
    height: 100vh;
    background-color: #f5ede3;
    z-index: 1000;
    box-shadow: -10px 0 30px rgba(0, 0, 0, 0);
    transform: translateX(100%);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
    display: flex;
    flex-direction: column;
  }
  .cart-sidebar.active {
    transform: translateX(0);
    box-shadow: -10px 0 40px rgba(0, 0, 0, 0.15);
  }
  .cart-header {
    padding: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
  }
  .close-cart {
    align-self: flex-end;
    margin-bottom: 1rem;
  }
  .cart-header h2 {
    margin: 0;
    color: #4a4a4a;
    font-size: 1.5rem;
    font-weight: normal;
    text-transform: uppercase;
  }
  .cart-separator {
    border: none;
    height: 1px;
    background-color: #dbd3ca;
    margin: 0;
  }
  .cart-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    color: #4a4a4a;
  }
  .cart-content p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .btn-catalog {
    background-color: #4a4a4a;
    color: #f5ede3;
    text-decoration: none;
    padding: 0.8rem 1.5rem;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 1px;
    transition: background-color 0.3s ease-in-out;
  }
  .btn-catalog:hover {
    background-color: #d4a373;
  }
</style>

<script>
  const openSearchBtn = document.getElementById('open-search');
  const closeSearchBtn = document.getElementById('close-search');
  const siteHeader = document.getElementById('site-header');
  const searchInput = document.getElementById('search-input');
  const openCartBtn = document.getElementById('open-cart');
  const closeCartBtn = document.getElementById('close-cart');
  const cartSidebar = document.getElementById('cart-sidebar');
  const cartOverlay = document.getElementById('cart-overlay');

  if (openSearchBtn && closeSearchBtn && siteHeader && searchInput) {
    openSearchBtn.addEventListener('click', (e) => {
      e.preventDefault();
      siteHeader.classList.add('search-active');
      searchInput.focus(); 
    });
    closeSearchBtn.addEventListener('click', (e) => {
      e.preventDefault();
      siteHeader.classList.remove('search-active');
      searchInput.value = ''; 
    });
  }

  if (openCartBtn && closeCartBtn && cartSidebar && cartOverlay) {
    openCartBtn.addEventListener('click', (e) => {
      e.preventDefault();
      cartSidebar.classList.add('active');
      cartOverlay.classList.add('active');
    });
    const closeCart = (e) => {
      e?.preventDefault();
      cartSidebar.classList.remove('active');
      cartOverlay.classList.remove('active');
    };

    closeCartBtn.addEventListener('click', closeCart);
    cartOverlay.addEventListener('click', closeCart);
  }
</script>